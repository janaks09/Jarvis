#Livekit Configuration. Can be local hosted or livekit cloud.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LLM Configuration
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# STT and TTS Configuration
ELEVEN_API_KEY=
DEEPGRAM_API_KEY=
PERPLEXITY_API_KEY=
CARTESIA_API_KEY=

# Personalization (used for wake word, instructions, and greeting)
ASSISTANT_NAME=Jarvis
ASSISTANT_GREETING=Hello There!
USER_NAME=User
USER_COUNTRY=Canada

# Seconds of silence before the assistant auto-mutes itself. Say the wake word
# (e.g. "hey jarvis") to resume. Set to 0/none to disable auto-mute.
USER_AWAY_TIMEOUT=10